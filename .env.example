# Startup Playbook — API Credentials
# Copy this file to .env and fill in your keys.
# Alternatively, place in ~/.startup-playbook/.env for user-level defaults.
# Environment variables always take highest priority.

# ── Reddit OAuth2 (free, 100 requests/min) ──
# Create app at https://www.reddit.com/prefs/apps → "script" type
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=

# ── GitHub (free, 5000 requests/hour) ──
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Product Hunt (free) ──
# Create at https://www.producthunt.com/v2/oauth/applications
PRODUCT_HUNT_TOKEN=

# ── Google Cloud (for GA4 + Search Console) ──
# Service account JSON path
GOOGLE_APPLICATION_CREDENTIALS=
GA4_PROPERTY_ID=
SEARCH_CONSOLE_SITE_URL=

# ── Search APIs (pick one) ──
# Serper.dev — $50/mo for 2500 queries: https://serper.dev
SERPER_API_KEY=
# SerpAPI — alternative: https://serpapi.com
SERPAPI_KEY=

# ── Keywords ──
# Keywords Everywhere — $10 for 100k credits: https://keywordseverywhere.com/
KEYWORDS_EVERYWHERE_API_KEY=

# ── China Market (optional) ──
BAIDU_TONGJI_SITE_ID=
BAIDU_TONGJI_ACCESS_TOKEN=
UMENG_APP_KEY=

# ── Proxy (optional) ──
HTTP_PROXY=
HTTPS_PROXY=
